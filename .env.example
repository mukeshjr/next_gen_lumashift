# ─── Supabase (Required for auth + user data) ────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── AI Chatbot (Optional) ────────────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Form Submissions (Optional) ─────────────────────────────────────────────
# Google Apps Script Web App URL (from deployment)
NEXT_PUBLIC_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ─── SEO & Contact (Optional) ────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://lumashift.com
NEXT_PUBLIC_CONTACT_EMAIL=lumashift@outlook.com
